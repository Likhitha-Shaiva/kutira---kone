rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // Phase 3: Primitives
    // -------------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // -------------------------------------------------------------------------
    // Phase 4: Validation Blueprints
    // -------------------------------------------------------------------------

    function isValidListing(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 100
        && data.material in ['Cotton', 'Silk', 'Wool', 'Linen', 'Polyester', 'Denim', 'Other']
        && data.status in ['available', 'reserved', 'exchanged']
        && data.type in ['swap', 'buy', 'free']
        && data.ownerId == request.auth.uid
        && (data.type != 'buy' || (data.price is number && data.price >= 0))
        && data.createdAt == request.time;
    }

    function isValidSwapRequest(data, listingId) {
      let listingDoc = get(/databases/$(database)/documents/listings/$(listingId)).data;
      return data.listingId == listingId
        && data.ownerId == listingDoc.ownerId
        && data.requesterId == request.auth.uid
        && data.status == 'pending'
        && data.createdAt == request.time;
    }

    function isValidUser(data, userId) {
      return data.id == userId
        && data.displayName is string && data.displayName.size() <= 50
        && data.email is string && data.email.size() <= 100;
    }

    // -------------------------------------------------------------------------
    // Collection Match Blocks
    // -------------------------------------------------------------------------

    // Listings
    match /listings/{listingId} {
      allow get: if isValidId(listingId);
      allow list: if true; // Public listings are okay to list/search
      
      allow create: if isSignedIn() 
        && isValidId(listingId)
        && isValidListing(incoming());
        
      allow update: if isSignedIn()
        && isOwner(existing().ownerId)
        && incoming().ownerId == existing().ownerId
        && incoming().createdAt == existing().createdAt
        && (
          // Action: Edit details
          (incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'material', 'color', 'size', 'imageUrl', 'location', 'type', 'price', 'status', 'updatedAt'])
           && (incoming().status == existing().status || incoming().status in ['available', 'reserved', 'exchanged'])
           && incoming().updatedAt == request.time)
        );
        
      allow delete: if isOwner(existing().ownerId);

      // Swap Requests (subcollection)
      match /swapRequests/{requestId} {
        allow get: if isSignedIn() && (
          isOwner(resource.data.requesterId) || 
          isOwner(get(/databases/$(database)/documents/listings/$(listingId)).data.ownerId)
        );
        
        allow list: if isSignedIn(); // Queries MUST filter by requesterId OR ownerId
        
        allow create: if isSignedIn()
          && isValidId(requestId)
          && isValidSwapRequest(incoming(), listingId);
          
        allow update: if isSignedIn() && (
          // Requester can cancel
          (isOwner(existing().requesterId) && incoming().status == 'cancelled' && incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
          // Owner can accept/decline
          (isOwner(get(/databases/$(database)/documents/listings/$(listingId)).data.ownerId) 
           && incoming().status in ['accepted', 'declined']
           && incoming().diff(existing()).affectedKeys().hasOnly(['status']))
        );
      }
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) && isValidUser(incoming(), userId);
    }
  }
}
